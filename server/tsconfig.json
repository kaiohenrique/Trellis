{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": false,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@kb/shared": ["../shared/types.ts"],
      "@kb/shared/*": ["../shared/*"]
    }
  },
  "include": ["**/*.ts", "../shared/types.ts"],
  "exclude": ["dist", "node_modules"]
}
